{
  "cleanupPeriodDays": 100000,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent(*)",
      "WebSearch",
      "WebFetch(*)",
      "Skill(update-config)",
      "Bash(git *)",
      "Bash(gh:*)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue *)",
      "Bash(gh api *)",
      "Bash(databricks *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(pip *)",
      "Bash(brew *)",
      "Bash(npm *)",
      "Bash(ntfy *)",
      "Bash(claude *)",
      "Bash(python3:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(chmod:*)",
      "Bash(pbcopy)",
      "Bash(env)",
      "Bash(source *)",
      "Bash(acli jira:*)",
      "Bash(~/bin/slack-clip:*)",
      "Bash(osascript -)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_take_screenshot",
      "mcp__plugin_playwright_playwright__browser_install",
      "mcp__plugin_databricks-ai-dev-kit_databricks__manage_workspace",
      "mcp__plugin_databricks-ai-dev-kit_databricks__execute_sql",
      "mcp__plugin_databricks-ai-dev-kit_databricks__get_table_details",
      "mcp__plugin_databricks-ai-dev-kit_databricks__get_vs_index",
      "mcp__plugin_databricks-ai-dev-kit_databricks__get_vs_endpoint",
      "mcp__plugin_databricks-ai-dev-kit_databricks__manage_job_runs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(git rev-parse --show-toplevel 2>/dev/null)\" = \"$HOME/lib/notes\" ]; then exit 0; fi; if git branch --show-current 2>/dev/null | grep -qE '^(main|master)$'; then echo 'BLOCK: Create a feature branch first. Do not commit directly to main.' >&2; exit 2; fi",
            "if": "Bash(git commit*)"
          },
          {
            "type": "command",
            "command": "bash ~/bin/dotfiles/claude/hooks/check-pr-before-push.sh 2>/dev/null || true",
            "if": "Bash(git push*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"A git push just happened. You MUST immediately: (1) Check if there is an open PR for this branch using gh pr view. If so, compare the PR description to the full commit history (git log main..HEAD). If the description is stale or missing recent changes, update it now using gh pr edit. (2) Check if the README needs updating. If so, update it, commit, and push. Do not ask for permission - just do it. If everything is current, say nothing.\"}'",
            "if": "Bash(git push*)"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ntfy publish claude-oren-e2ecee87 \"Claude Code needs attention in: $(basename $(pwd))\" 2>/dev/null; afplay /System/Library/Sounds/Glass.aiff 2>/dev/null &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/bin/dotfiles/claude/hooks/extract-corrections.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/bin/dotfiles/claude/hooks/check-workshop-schedule.sh"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/bin/dotfiles/claude/hooks/validate-instructions.py"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) changed: $(cat | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('source','?'), d.get('file_path','?'))\" 2>/dev/null)\" >> ~/.claude/config-audit.log"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"---\n$(date -u +%Y-%m-%dT%H:%M:%SZ)\n$(cat | python3 -c \"import sys,json; print(json.load(sys.stdin).get('compact_summary',''))\" 2>/dev/null)\n\" >> ~/.claude/compaction-log.md"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "jira@ai-platform": true,
    "ecosystem@ai-platform": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "databricks-ai-dev-kit@databricks-ai-dev-kit": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "self-improve@ai-platform": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ai-platform": {
      "source": {
        "source": "directory",
        "path": "/Users/oren.dobzinski/lib/ai-platform-dev-tools"
      },
      "autoUpdate": true
    },
    "databricks-ai-dev-kit": {
      "source": {
        "source": "github",
        "repo": "databricks-solutions/ai-dev-kit"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "high",
  "additionalDirectories": [
    {
      "path": "~/lib/notes",
      "readClaudeMd": true
    },
    {
      "path": "~/lib/scribe/ai-scribe-model"
    },
    {
      "path": "~/lib/scribe/ai-scribe-rags"
    },
    {
      "path": "~/lib/scribe/ai-iac-model-serving"
    },
    {
      "path": "~/lib/scribe/ai-scribe-training-data"
    },
    {
      "path": "~/lib/scribe/ai-scribe-evals"
    }
  ]
}
