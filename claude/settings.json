{
  "cleanupPeriodDays": 100000,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if git branch --show-current 2>/dev/null | grep -qE '^(main|master)$'; then echo 'BLOCK: Create a feature branch first. Do not commit directly to main.' >&2; exit 2; fi",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"A git push just happened. You MUST immediately: (1) Check if there is an open PR for this branch using gh pr view. If so, compare the PR description to the full commit history (git log main..HEAD). If the description is stale or missing recent changes, update it now using gh pr edit. (2) Check if the README needs updating. If so, update it, commit, and push. Do not ask for permission - just do it. If everything is current, say nothing.\"}'",
            "if": "Bash(git push*)"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ntfy publish claude-oren-e2ecee87 \"Claude Code needs attention in: $(basename $(pwd))\" 2>/dev/null; afplay /System/Library/Sounds/Glass.aiff 2>/dev/null &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/bin/dotfiles/claude/hooks/extract-corrections.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/bin/dotfiles/claude/hooks/check-whats-new-schedule.sh"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/bin/dotfiles/claude/hooks/validate-instructions.py"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) changed: $(cat | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('source','?'), d.get('file_path','?'))\" 2>/dev/null)\" >> ~/.claude/config-audit.log"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"---\n$(date -u +%Y-%m-%dT%H:%M:%SZ)\n$(cat | python3 -c \"import sys,json; print(json.load(sys.stdin).get('compact_summary',''))\" 2>/dev/null)\n\" >> ~/.claude/compaction-log.md"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "jira@ai-platform": true,
    "ecosystem@ai-platform": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "databricks-ai-dev-kit@databricks-ai-dev-kit": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "self-improve@ai-platform": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ai-platform": {
      "source": {
        "source": "directory",
        "path": "/Users/oren.dobzinski/lib/ai-platform-dev-tools"
      },
      "autoUpdate": true
    },
    "databricks-ai-dev-kit": {
      "source": {
        "source": "github",
        "repo": "databricks-solutions/ai-dev-kit"
      }
    }
  },
  "effortLevel": "high",
  "additionalDirectories": [
    {
      "path": "~/lib/notes",
      "readClaudeMd": true
    }
  ]
}
